// Panel-local *view* state for the timeline. Anything in here is ephemeral
// UI ("where is the user currently looking?") and is not part of the
// project, not persisted, and not addressable by the agent command layer.
// Domain timeline state (zoom, playhead, selection, marks, …) lives in
// `TimelineStore` (see `ui/store/timeline-store.slint`).
export global TimelineViewState {
    in-out property <length> scroll-x: 0px;
    in-out property <length> scroll-y: 0px;
}
