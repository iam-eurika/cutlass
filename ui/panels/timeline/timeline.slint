import {
    CutlassText,
    HorizontalDivider,
    PanelBase,
    CutlassScrollView,
    VerticalDivider,
} from "../../components/index.slint";
import { AppStore } from "../../store/index.slint";
import { Toolbar } from "toolbar.slint";
import { TrackLane } from "track-lane.slint";
import { TrackHead } from "track-head.slint";
import { Ruler } from "ruler.slint";
import { ClipView } from "clip.slint";
import { TimelineState } from "state.slint";
import { Sequence } from "../../models/index.slint";
import { EditorStore } from "../../store/index.slint";
import { TimelineLib } from "../../lib/timeline-lib.slint";



component ForceHeadSpace inherits Rectangle {

    height: AppStore.theme.track-lane.height;

    background: transparent;
}

export component TimelinePanel inherits PanelBase {

    private property <length> track-spacing: AppStore.theme.metrics.spacing.sm;
    private property <length> track-height: AppStore.theme.track-lane.height;
    property <Sequence> sequence: EditorStore.project.sequence;

    VerticalLayout {

        spacing: AppStore.theme.metrics.spacing.none;

        tb := Toolbar {
            height: AppStore.theme.metrics.layout.toolbar-height;
        }

        rl := Ruler { }

        // A `Flickable`'s preferred-height equals its `viewport-height`
        // (see Slint docs). That propagates up through `HorizontalLayout`
        // and makes this row claim the full panel height instead of just
        // the remainder after toolbar+ruler — overflowing the panel and
        // leaving no scroll range. Pin the row to the leftover space.
        HorizontalLayout {

            height: root.height - tb.height - rl.height;
            spacing: 60px;
            Rectangle {
                height: 100%;
                width: 100px;

                Flickable {
                    viewport-y <=> TimelineState.scroll-y;

                    viewport-height: max(self.height, TimelineLib.calc-viewport-height(
                        sequence.tracks.length + 1 /* +1 for the head space */,
                        track-height,
                        track-spacing,
                    ));

                    VerticalLayout {
                        vertical-stretch: 1;
                        horizontal-stretch: 1;
                        spacing: track-spacing;

                        ForceHeadSpace { }

                        for t in sequence.tracks: TrackHead { }
                    }
                }

                VerticalDivider {
                    x: parent.width - self.width;
                    width: AppStore.theme.metrics.stroke.thin;
                }
            }

            Flickable {
                viewport-width: 1000000px;
                viewport-height: max(self.height, TimelineLib.calc-viewport-height(
                    sequence.tracks.length + 1 /* +1 for the head space */,
                    track-height,
                    track-spacing,
                ));

                viewport-y <=> TimelineState.scroll-y;
                viewport-x <=> TimelineState.scroll-x;

                VerticalLayout {
                    vertical-stretch: 1;
                    horizontal-stretch: 1;
                    spacing: track-spacing;

                    ForceHeadSpace { }

                    for t in sequence.tracks: TrackLane {
                        for c in t.clips: ClipView {
                            model: c;
                            height: parent.height - 2px;
                            zoom: TimelineState.zoom;
                        }
                    }
                }
            }
        }
    }
}
