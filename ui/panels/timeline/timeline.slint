import { HorizontalDivider } from "../../components/divider.slint";
import { PanelBase } from "../../components/panel-base.slint";
import { CutlassText } from "../../components/text.slint";
import { AppStore } from "../../store/app-store.slint";
export component TimelinePanel inherits PanelBase {
    VerticalLayout {
        spacing: AppStore.theme.metrics.spacing.none;

        Rectangle {
            height: AppStore.theme.metrics.layout.toolbar-height;

            CutlassText {
                text: "Tools";
                style: AppStore.theme.typography.label;
            }

            HorizontalDivider {
                y: parent.height - self.height;
            }
        }
    }
}
