import { RationalTime } from "../models/index.slint";

// Rust-backed edit commands for the project / timeline.
//
// Read-only queries live on `TimelineLib`; mutations live here so the
// engine, undo stack, and agent command layer share one code path.

export global EditorBackend {
    // Reposition a clip on the sequence timeline.
    //
    // Arguments:
    //   clip-id         — stable clip identity
    //   track-id        — track containing the clip
    //   timeline-start  — new position in sequence-rate ticks
    callback move-clip(string, string, RationalTime);
}
