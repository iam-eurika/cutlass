// Bridge between the timeline ruler component and the Rust tick generator.
//
// The Slint side reports the current viewport state (scroll offset,
// width, zoom, project frame rate); Rust returns the *visible* tick
// marks already positioned in viewport-local pixel coordinates, with
// SMPTE timecode labels on majors.
//
// Why a Rust-backed callback and not pure Slint?
//
//   * Slint can't construct arrays procedurally — `for` only iterates
//     models that already exist. So somebody outside Slint has to build
//     the tick list.
//   * SMPTE drop-frame timecode formatting is the kind of integer
//     arithmetic that's painful in Slint expressions and trivial in
//     Rust (see `src/timecode.rs`).
//   * Putting the formatter in Rust gives us *one* source of truth for
//     timecode that the inspector, export, and agent command layers
//     can all reuse later.
//
// Reactivity model: Slint re-invokes a `pure` callback whenever any
// property *read to compute its arguments* changes. So the ruler
// declares `for tick in RulerBackend.ticks(scroll, width, zoom, ...)`
// and the tick list refreshes automatically on every scroll, zoom,
// resize, or fps switch. No manual invalidation.

export struct RulerTick {
    // Viewport-local x position (already includes the scroll offset).
    // Rounded to whole logical pixels in Rust so 1px tick lines don't
    // smear across two subpixels.
    x: length,

    // Major ticks are tall (~12px) and carry a non-empty `label`.
    // Minor ticks are short (~5px) visual subdivisions; `label == ""`.
    is-major: bool,

    // SMPTE timecode for major ticks: "HH:MM:SS:FF" (non-drop, `:`) or
    // "HH:MM:SS;FF" (drop-frame, `;`). Always empty for minor ticks.
    label: string,
}

export global RulerBackend {
    // Returns the ticks visible in the current viewport, already laid
    // out in viewport-local coordinates.
    //
    // Arguments (positional — Slint callbacks don't support named args):
    //   1. scroll-x   — Flickable.viewport-x; negative when scrolled right
    //   2. viewport-w — width of the ruler in logical px
    //   3. zoom       — TimelineStore.zoom; px per *frame* of the sequence
    //   4. fps-num    — sequence frame rate numerator (e.g. 24000 for 23.976)
    //   5. fps-den    — sequence frame rate denominator (e.g. 1001)
    //   6. drop-frame — render SMPTE drop-frame timecode (only meaningful for NTSC)
    //
    // The handler is installed from Rust in `src/main.rs`.
    pure callback ticks(length, length, float, int, int, bool) -> [RulerTick];
}
