import { AppStore } from "../store/app-store.slint";

// Draggable split grips. Window-space drag (`absolute-position` + `mouse`) avoids jitter
// when the grip moves with layout (see slint-ui/slint#6949).

export component HSplitGripLead inherits Rectangle {
    width: AppStore.theme.metrics.layout.split-grip;
    horizontal-stretch: 0;

    in-out property <length> pane-width;
    in property <length> min-pane: AppStore.theme.metrics.layout.min-pane-width;
    in property <length> max-pane: AppStore.theme.metrics.layout.max-pane-width;

    background: ta.has-hover ? AppStore.theme.split-grip.hover : AppStore.theme.split-grip.normal;

    ta := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: MouseCursor.col-resize;

        property <length> drag-start-pane-width;
        property <length> drag-origin-root-x;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                self.drag-start-pane-width = root.pane-width;
                self.drag-origin-root-x = self.absolute-position.x + self.mouse-x;
            }
        }

        moved() => {
            if (!self.pressed) {
                return;
            }
            root.pane-width = self.drag-start-pane-width + self.absolute-position.x + self.mouse-x - self.drag-origin-root-x;
            root.pane-width = root.pane-width < root.min-pane ? root.min-pane : root.pane-width;
            root.pane-width = root.pane-width > root.max-pane ? root.max-pane : root.pane-width;
        }
    }
}

// Right edge of the right column: drag right → narrower right pane.
export component HSplitGripTrail inherits Rectangle {
    width: AppStore.theme.metrics.layout.split-grip;
    horizontal-stretch: 0;

    in-out property <length> pane-width;
    in property <length> min-pane: AppStore.theme.metrics.layout.min-pane-width;
    in property <length> max-pane: AppStore.theme.metrics.layout.max-pane-width;

    background: ta.has-hover ? AppStore.theme.split-grip.hover : AppStore.theme.split-grip.normal;

    ta := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: MouseCursor.col-resize;

        property <length> drag-start-pane-width;
        property <length> drag-origin-root-x;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                self.drag-start-pane-width = root.pane-width;
                self.drag-origin-root-x = self.absolute-position.x + self.mouse-x;
            }
        }

        moved() => {
            if (!self.pressed) {
                return;
            }
            root.pane-width = self.drag-start-pane-width - (self.absolute-position.x + self.mouse-x - self.drag-origin-root-x);
            root.pane-width = root.pane-width < root.min-pane ? root.min-pane : root.pane-width;
            root.pane-width = root.pane-width > root.max-pane ? root.max-pane : root.pane-width;
        }
    }
}

// Horizontal strip above the timeline: drag adjusts timeline height.
export component VSplitGripTimeline inherits Rectangle {
    height: AppStore.theme.metrics.layout.split-grip;
    horizontal-stretch: 1;

    in-out property <length> timeline-height;
    in property <length> min-timeline: AppStore.theme.metrics.layout.min-timeline-height;
    in property <length> max-timeline: AppStore.theme.metrics.layout.max-timeline-height;

    background: ta.has-hover ? AppStore.theme.split-grip.hover : AppStore.theme.split-grip.normal;

    ta := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: MouseCursor.row-resize;

        property <length> drag-start-timeline-height;
        property <length> drag-origin-root-y;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                self.drag-start-timeline-height = root.timeline-height;
                self.drag-origin-root-y = self.absolute-position.y + self.mouse-y;
            }
        }

        moved() => {
            if (!self.pressed) {
                return;
            }
            root.timeline-height = self.drag-start-timeline-height - (self.absolute-position.y + self.mouse-y - self.drag-origin-root-y);
            root.timeline-height = root.timeline-height < root.min-timeline ? root.min-timeline : root.timeline-height;
            root.timeline-height = root.timeline-height > root.max-timeline ? root.max-timeline : root.timeline-height;
        }
    }
}
