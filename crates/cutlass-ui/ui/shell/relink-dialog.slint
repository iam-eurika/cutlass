// Missing-media relink dialog (v1 roadmap M0): an in-window modal in the
// export-dialog mold (in-window so it lives inside the frameless shell).
// Mounted by app.slint while `AppState.relink-dialog-open` is set — the
// session-epoch watcher raises it when a freshly opened/restored project
// has pool entries whose file is gone. Each row's "Locate…" routes through
// `EditorStore.on-relink-media-requested` → main.rs (async file picker) →
// the worker, which re-probes the picked file, swaps the entry's path in
// place, and republishes; the count hitting zero closes the dialog.
// "Locate folder" batch-relinks: every missing entry whose file name is
// found in the picked folder recovers in one pass.
// "Later" dismisses — the library tiles keep their missing badges, and
// each badge offers the same Locate… flow.

import { CutlassText, AccentButton, SubtleButton } from "../components/index.slint";
import { AppStore, EditorStore } from "../store/index.slint";
import { AppState } from "../state.slint";

export component RelinkDialog inherits Rectangle {
    background: #000000A0;

    // Self-close once the last entry relinks (the worker republishes the
    // count with every projection).
    private property <int> missing-count: EditorStore.missing-media-count;

    changed missing-count => {
        if (self.missing-count == 0) {
            AppState.relink-dialog-open = false;
        }
    }

    // Scrim: absorb every pointer event so the editor underneath is inert.
    TouchArea { }

    panel := Rectangle {
        width: 520px;
        height: content.preferred-height;
        background: AppStore.theme.panel.background;
        border-radius: AppStore.theme.metrics.radius.lg;
        border-width: 1px;
        border-color: #ffffff14;
        drop-shadow-blur: 32px;
        drop-shadow-color: #00000080;
        drop-shadow-offset-y: 8px;

        // Keep clicks inside the panel from reaching the scrim above.
        TouchArea { }

        content := VerticalLayout {
            padding: AppStore.theme.metrics.spacing.xl;
            spacing: AppStore.theme.metrics.spacing.lg;

            CutlassText {
                text: "Relink missing media";
                style: AppStore.theme.typography.heading-md;
            }

            CutlassText {
                text: "Some files in this project moved or were deleted. Clips stay on the timeline; locate each file to restore its preview and playback.";
                wrap: word-wrap;
                style: AppStore.theme.typography.caption;
                foreground: AppStore.theme.text.secondary;
            }

            // One row per missing entry. Slint's `for` can't filter a
            // model, so rows for present media collapse to zero height.
            VerticalLayout {
                spacing: 0;

                for media in EditorStore.project.media: Rectangle {
                    visible: media.is-missing;
                    height: media.is-missing ? 48px : 0;

                    HorizontalLayout {
                        spacing: AppStore.theme.metrics.spacing.sm;
                        padding-top: AppStore.theme.metrics.spacing.sm;
                        padding-bottom: AppStore.theme.metrics.spacing.sm;

                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 2px;
                            alignment: center;

                            CutlassText {
                                text: media.name;
                                overflow: elide;
                                style: AppStore.theme.typography.label;
                            }

                            // Where the file used to live — the best hint
                            // for hunting it down.
                            CutlassText {
                                text: media.path;
                                overflow: elide;
                                style: AppStore.theme.typography.caption;
                                foreground: AppStore.theme.text.muted;
                            }
                        }

                        VerticalLayout {
                            alignment: center;

                            AccentButton {
                                label: "Locate…";
                                clicked => {
                                    EditorStore.on-relink-media-requested(media.id);
                                }
                            }
                        }
                    }
                }
            }

            HorizontalLayout {
                spacing: AppStore.theme.metrics.spacing.md;

                SubtleButton {
                    label: "Locate folder";
                    enabled: root.missing-count > 0;
                    clicked => {
                        EditorStore.on-relink-folder-requested();
                    }
                }

                Rectangle {
                    horizontal-stretch: 1;
                }

                SubtleButton {
                    label: "Later";
                    clicked => {
                        AppState.relink-dialog-open = false;
                    }
                }
            }
        }
    }
}
