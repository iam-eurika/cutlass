// Native window chrome, implemented in Rust (src/main.rs). The window is
// frameless (`no-frame` on AppWindow), so the custom title bar drives the
// OS window through these callbacks instead of native decorations.
export global WindowBackend {
    // Mirrors the OS maximized state so the maximize button can flip its
    // glyph; Rust updates it whenever it changes the window state.
    in-out property <bool> maximized: false;

    callback minimize();
    callback toggle-maximize();
    // Drive the OS maximized state directly (Rust mirrors `maximized` back).
    // Used to size the window to the active surface: the launch screen opens
    // at the window's natural size, the editor maximizes.
    callback set-maximized(maximized: bool);
    callback close();
    // Start an OS-driven window move. Must be called while a pointer
    // button is down (the title bar's drag TouchArea); once the system
    // move begins the OS owns the gesture and no further pointer events
    // reach the app until release.
    callback begin-move();
}
