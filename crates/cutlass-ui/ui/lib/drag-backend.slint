import { Sequence } from "../models/index.slint";

// Bridge between the timeline clip-drag gesture and the Rust snap helpers.
// Each drag frame the gesture layer calls `DragBackend.snap-clip-start(...)`
// with the current sequence snapshot and gets back a possibly-adjusted start
// tick plus the timeline tick where the snap guide line should be drawn.
//
// Reactivity: pure callbacks re-invoke whenever arguments change during drag.

export struct SnapResult {
    has-snap: bool,
    snapped-start-value: int,
    snap-line-tick: int,
}

export struct ResolvedTarget {
    track-id: string,
    clamped-offset: int,
}

export global DragBackend {
    pure callback snap-clip-start(Sequence /* sequence */, string /* dragging-source-track-id */, string /* dragging-clip-id */, int    /* cursor-start-value */, int    /* clip-duration-ticks */, int    /* snap-threshold-ticks */, ) -> SnapResult;

    pure callback resolve-target-lane(Sequence /* sequence */, string /* source-track-id */, int    /* lane-offset */, ) -> ResolvedTarget;
}
