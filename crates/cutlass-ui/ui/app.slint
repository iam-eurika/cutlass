import {
    CutlassText,
    HSplitGripLead,
    HSplitGripTrail,
    VSplitGripTimeline,
} from "components/index.slint";
import {
    InspectorPanel,
    LibraryPanel,
    PreviewPanel,
    TimelinePanel,
} from "panels/index.slint";
import { AppStore, EditorStore, TimelineStore } from "store/index.slint";
import { AppState } from "state.slint";
import { FullscreenPreview } from "fullscreen-preview.slint";

// Re-export globals so Slint's codegen generates accessors on `AppWindow`.
// Slint only exposes globals from the entry file's exports to the host
// language (Rust here) — transitive imports aren't enough.
//   https://docs.slint.dev/latest/docs/slint/src/language/syntax/globals
export { AppState }from "state.slint";
export { EditorStore, TimelineStore, PreviewStore }from "store/index.slint";
export { TimelineViewState }from "panels/timeline/index.slint";
export { TimelineLib }from "lib/index.slint";
export { RulerBackend, RulerTick }from "lib/ruler-backend.slint";
export {
    DragBackend,
    SnapResult,
    ClipDragResolution,
    ClipTrimResolution,
}from "lib/drag-backend.slint";
export { InspectorBackend, SelectedClipInfo }from "lib/inspector-backend.slint";

export component AppWindow inherits Window {
    title: "Cutlass";

    preferred-width: 1280px;
    preferred-height: 800px;

    default-font-size: AppStore.theme.typography.body.size;
    default-font-weight: AppStore.theme.typography.body.weight;

    full-screen: AppState.preview-maximized;

    in-out property <length> left-pane-width: 350px;
    in-out property <length> right-pane-width: 350px;
    in-out property <length> timeline-height: 400px;

    background: AppState.preview-maximized ? AppStore.theme.panel.background : AppStore.theme.surface.app-background;

    if AppState.preview-maximized: FullscreenPreview {
        width: root.width;
        height: root.height;
    }

    if !AppState.preview-maximized: VerticalLayout {
        padding: AppStore.theme.metrics.spacing.sm;
        spacing: AppStore.theme.metrics.spacing.none;

        Rectangle {
            height: 40px;
            background: AppStore.theme.surface.app-background;
            CutlassText {
                text: "Cutlass Head";
                style: AppStore.theme.typography.label;
            }
        }

        HorizontalLayout {
            vertical-stretch: 1;
            horizontal-stretch: 1;
            spacing: AppStore.theme.metrics.spacing.none;

            LibraryPanel {
                width: root.left-pane-width;
                vertical-stretch: 1;
            }

            HSplitGripLead {
                pane-width <=> root.left-pane-width;
                vertical-stretch: 1;
            }

            PreviewPanel {
                vertical-stretch: 1;
                horizontal-stretch: 1;
            }

            HSplitGripTrail {
                pane-width <=> root.right-pane-width;
                vertical-stretch: 1;
            }

            InspectorPanel {
                width: root.right-pane-width;
                vertical-stretch: 1;
            }
        }

        VSplitGripTimeline {
            timeline-height <=> root.timeline-height;
        }

        TimelinePanel {
            height: root.timeline-height;
            horizontal-stretch: 1;
        }
    }

    // Library drag ghost — must live at window scope so it paints above all
    // panels. `z` on a nested element only stacks within its parent; PanelBase
    // also clips children to the panel bounds.
    private property <length> library-ghost-clip-h:
        AppStore.theme.track-lane.clip.height - 5px;
    private property <length> library-ghost-clip-w:
        AppState.library-drag-duration-ticks * TimelineStore.zoom * 1px;

    if AppState.library-drag-active: Rectangle {
        width: AppState.library-drag-over-timeline ? root.library-ghost-clip-w : AppState.library-drag-w;
        height: AppState.library-drag-over-timeline ? root.library-ghost-clip-h : AppState.library-drag-h;
        x: AppState.library-drag-cursor-x - (AppState.library-drag-over-timeline ? 0px : AppState.library-drag-tile-anchor-x);
        y: AppState.library-drag-cursor-y - (AppState.library-drag-over-timeline ? root.library-ghost-clip-h / 2 : AppState.library-drag-tile-anchor-y);
        background: AppState.library-drag-over-timeline ? green : red;
        border-radius: AppStore.theme.track-lane.clip.radius;
        animate width, height { duration: 120ms; easing: ease-out; }
    }
}
