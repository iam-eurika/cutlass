import {
    CutlassGridView,
    CutlassText,
    PanelBase,
    PanelHeader,
} from "../../components/index.slint";
import { AppStore, EditorStore } from "../../store/index.slint";
import { AppState } from "../../state.slint";
import { Media, TrackKind } from "../../models/index.slint";
import { Button } from "std-widgets.slint";

// One draggable tile in the "Titles & shapes" strip. Dragging reuses the
// library-drag state machine (window ghost + timeline landing ghost); the
// payload carries a generator catalog key instead of a media id, and the
// commit fires EditorStore.on-generated-dropped.
component GeneratedTile inherits Rectangle {
    // Catalog key: "text" | "solid" | "rect" | "ellipse".
    in property <string> generator;
    in property <string> label;
    // Lane kind this generator lives on (text titles → text, the rest → sticker).
    in property <TrackKind> lane-kind;
    // Default placement length in seconds (text 3s, solids/shapes 5s).
    in property <int> seconds;
    // Preview swatch fill.
    in property <color> swatch;
    // Draw the swatch as an ellipse rather than a rectangle.
    in property <bool> round-swatch: false;

    property <int> fps-num: EditorStore.project.sequence.fps.num;
    property <int> fps-den: EditorStore.project.sequence.fps.den;

    background: AppStore.theme.surface.content-background;
    border-radius: 4px;
    clip: true;

    Rectangle {
        width: 44px;
        height: 44px;
        y: 12px;
        background: root.swatch;
        border-radius: root.round-swatch ? self.width / 2 : 4px;
    }

    VerticalLayout {
        alignment: end;
        Rectangle {
            height: 22px;
            background: #000000a0;
            CutlassText {
                text: root.label;
                style: AppStore.theme.typography.label;
                overflow: elide;
                x: 4px;
                width: parent.width - 8px;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;

        pointer-event(event) => {
            if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                AppState.library-drag-media-id = "";
                AppState.library-drag-generator = root.generator;
                AppState.library-drag-lane-kind = root.lane-kind;
                AppState.library-drag-duration-ticks =
                    max(1, round(root.seconds * root.fps-num / root.fps-den));
                AppState.library-drag-w = parent.width;
                AppState.library-drag-h = parent.height;
                AppState.library-drag-tile-anchor-x = self.mouse-x;
                AppState.library-drag-tile-anchor-y = self.mouse-y;
                AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                AppState.library-drag-active = true;
            }
            if event.kind == PointerEventKind.up {
                AppState.library-drag-active = false;
            }
        }

        moved => {
            if !self.pressed || !AppState.library-drag-active {
                return;
            }
            AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
            AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
        }
    }
}

export component LibraryPanel inherits PanelBase {
    // Read-only projection of the engine media pool (see src/projection.rs).
    property <[Media]> media: EditorStore.project.media;

    VerticalLayout {
        spacing: AppStore.theme.metrics.spacing.none;

        PanelHeader {
            title: "Library";

            Button {
                text: "Import";
                x: 250px;
                clicked => {
                    EditorStore.on-import-clicked();
                }
            }
        }

        // "Titles & shapes": draggable generators that don't come from the
        // media pool. Drop one on the timeline to create a text / solid /
        // shape clip (see EditorStore.on-generated-dropped).
        VerticalLayout {
            padding: AppStore.theme.metrics.spacing.md;
            spacing: AppStore.theme.metrics.spacing.sm;

            CutlassText {
                text: "Titles & shapes";
                style: AppStore.theme.typography.label;
            }

            HorizontalLayout {
                spacing: AppStore.theme.metrics.spacing.md;
                height: 72px;

                GeneratedTile {
                    generator: "text";
                    label: "Text";
                    lane-kind: TrackKind.text;
                    seconds: 3;
                    swatch: #3A6FC8;
                }
                GeneratedTile {
                    generator: "solid";
                    label: "Solid";
                    lane-kind: TrackKind.sticker;
                    seconds: 5;
                    swatch: #1E1E1E;
                }
                GeneratedTile {
                    generator: "rect";
                    label: "Rectangle";
                    lane-kind: TrackKind.sticker;
                    seconds: 5;
                    swatch: #E0E0E0;
                }
                GeneratedTile {
                    generator: "ellipse";
                    label: "Ellipse";
                    lane-kind: TrackKind.sticker;
                    seconds: 5;
                    swatch: #E0E0E0;
                    round-swatch: true;
                }
            }
        }

        grid := CutlassGridView {
            show-horizontal-scrollbar: false;
            show-vertical-scrollbar: false;
            vertical-stretch: 1;
            horizontal-stretch: 1;

            columns: 3;
            cell-width: 100px;
            cell-height: 100px;
            spacing: AppStore.theme.metrics.spacing.md;
            inset: AppStore.theme.metrics.spacing.md;
            item-count: root.media.length;

            for m[i] in root.media: Rectangle {
                x: grid.cell-x(i);
                y: grid.cell-y(i);
                width: grid.cell-width;
                height: grid.cell-height;
                // Audio tiles show the waveform card color while the waveform
                // image is still rendering; video tiles stay dark until the
                // poster frame lands.
                background: m.is-audio ? #2A46C8 : AppStore.theme.surface.content-background;
                border-radius: 4px;
                clip: true;

                // Poster frame (video) or waveform card (audio), generated
                // off-thread after import — empty until ready.
                if m.thumbnail.width > 0: Image {
                    width: parent.width;
                    height: parent.height;
                    source: m.thumbnail;
                    image-fit: cover;
                }

                ta := TouchArea {
                    width: parent.width;
                    height: parent.height;

                    pointer-event(event) => {
                        if event.kind == PointerEventKind.down && event.button == PointerEventButton.left {
                            AppState.library-drag-media-id = m.id;
                            AppState.library-drag-generator = "";
                            AppState.library-drag-lane-kind = TrackKind.video;
                            AppState.library-drag-duration-ticks = m.duration-ticks;
                            AppState.library-drag-w = parent.width;
                            AppState.library-drag-h = parent.height;
                            AppState.library-drag-tile-anchor-x = self.mouse-x;
                            AppState.library-drag-tile-anchor-y = self.mouse-y;
                            AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                            AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                            AppState.library-drag-active = true;
                        }
                        if event.kind == PointerEventKind.up {
                            AppState.library-drag-active = false;
                        }
                    }

                    moved => {
                        if !self.pressed || !AppState.library-drag-active {
                            return;
                        }
                        AppState.library-drag-cursor-x = self.absolute-position.x + self.mouse-x;
                        AppState.library-drag-cursor-y = self.absolute-position.y + self.mouse-y;
                    }
                }
                // Duration badge, top-right like CapCut.
                Rectangle {
                    x: parent.width - self.width - 4px;
                    y: 4px;
                    width: duration-text.preferred-width + 8px;
                    height: duration-text.preferred-height + 4px;
                    background: #000000a0;
                    border-radius: 3px;
                    visible: m.duration-label != "";

                    duration-text := CutlassText {
                        x: 4px;
                        y: 2px;
                        text: m.duration-label;
                        style: AppStore.theme.typography.label;
                    }
                }

                // Name label strip along the bottom of the tile.
                VerticalLayout {
                    alignment: end;

                    Rectangle {
                        height: 22px;
                        background: #000000a0;

                        CutlassText {
                            text: m.name;
                            style: AppStore.theme.typography.label;
                            overflow: elide;
                            x: 4px;
                            width: parent.width - 8px;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
