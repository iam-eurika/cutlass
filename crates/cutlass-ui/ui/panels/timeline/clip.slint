import { AppStore, EditorStore } from "../../store/index.slint";
import { Clip, TrackKind } from "../../models/index.slint";
import { TimelineLib, StripBackend, SelectionBackend } from "../../lib/index.slint";
import { TimelineStore } from "../../store/timeline-store.slint";
import { TimelineViewState } from "state.slint";
import { AppState } from "../../state.slint";

// Named `model` because `clip` is a built-in Slint property on visual elements.
//
// The drag gesture only records state here (press snapshot + cursor deltas);
// TimelinePanel owns the resolution, the floating drag visual, the ghost, and
// the commit — the original clip just stays in place, dimmed, until the
// engine republishes the projection.
export component ClipView inherits Rectangle {
    in property <Clip> model;
    in property <string> track-id;
    in property <int> track-row;
    in property <TrackKind> track-kind;
    in property <color> track-color;
    // Lane header flags. Hidden (`!track-enabled`) lanes dim their clips;
    // locked lanes can't be selected, moved, or trimmed.
    in property <bool> track-enabled: true;
    in property <bool> track-locked: false;
    in property <float> zoom;

    private property <bool> is-active-drag:
        TimelineViewState.dragging-source-track-id == track-id
        && TimelineViewState.dragging-clip-id == model.id;

    private property <bool> is-active-trim:
        TimelineViewState.trimming-track-id == track-id
        && TimelineViewState.trimming-clip-id == model.id;

    private property <bool> is-selected:
        SelectionBackend.contains(TimelineStore.selected-ids, model.id);

    // Edge handles cap at a third of the clip so very short clips keep a
    // grabbable middle for the move gesture.
    private property <length> handle-width: min(6px, self.width / 3);

    // Selected members of an active group drag / linked trim: their floating
    // copies (or partner stretch previews) render above, so the originals dim
    // exactly like the grabbed clip does.
    private property <bool> rides-along: root.is-selected
        && ((TimelineViewState.drag-is-group && TimelineViewState.dragging-clip-id != "")
            || TimelineViewState.trimming-clip-id != "");

    // CapCut dims the source position while the floating copy (move) or the
    // stretch preview (trim) shows the live result; a hidden lane
    // (`!track-enabled`) stays dimmed for as long as it's off.
    //
    // Dim via per-element colors, NOT the group `opacity` property: opacity on
    // an element with children makes Slint composite the subtree into an
    // intermediate GPU texture sized to the element's full geometry. A long
    // clip at high zoom exceeds the GPU max texture dimension (16384 px) and
    // aborts the app inside wgpu.
    private property <bool> dimmed:
        is-active-drag || is-active-trim || rides-along || !track-enabled;

    // --- Phase 8: clip content (filmstrip / waveform / inline text) ------

    private property <bool> has-media: model.media-id != "";
    private property <bool> show-filmstrip: has-media && track-kind == TrackKind.video;
    private property <bool> show-waveform: has-media && track-kind == TrackKind.audio;
    private property <bool> is-text: track-kind == TrackKind.text;

    // Visible slice of this clip in 256px buckets of clip-local x, so
    // scrolling only re-resolves the tile model when a bucket boundary is
    // crossed (src/strips.rs pads by one tile). scroll-x is the Flickable
    // viewport-x: ≤ 0 when scrolled right.
    private property <int> vis-from-bucket: floor(
        (-TimelineViewState.scroll-x - root.x) / 256px);
    private property <int> vis-to-bucket: floor(
        (-TimelineViewState.scroll-x + TimelineViewState.viewport-w - root.x) / 256px);

    // The name/duration row needs space; hide labels on slivers entirely.
    private property <bool> show-labels: root.width > 40px;
    private property <length> label-row-h: 14px;

    x: TimelineLib.rational-to-length(model.timeline-start, zoom);

    width: TimelineLib.clip-timeline-width(model, zoom);
    height: AppStore.theme.track-lane.clip.height;
    background: dimmed ? track-color.with-alpha(0.35) : track-color;
    // Rounded clipping is the same GPU-layer trap as group `opacity` above:
    // `clip: true` with a non-zero radius composites the subtree into a
    // texture sized to the full card, which at frame-level zoom exceeds the
    // 16384px GPU texture limit and aborts in wgpu. Past a few thousand px
    // the 4px corners are imperceptible anyway — drop the radius so the clip
    // degrades to a plain scissor rect (no layer allocated at all).
    border-radius: root.width < 4096px ? AppStore.theme.track-lane.clip.radius : 0;
    // Tiles are grid-aligned to media time, so the first one usually starts
    // left of the clip edge — crop everything to the rounded card.
    clip: true;

    // Filmstrip: sampled source frames, decoded off-thread and cached per
    // media + power-of-two zoom bucket. Missing tiles draw nothing — the
    // lane-colored card shows through until the frame lands.
    if show-filmstrip: Rectangle {
        for tile in StripBackend.filmstrip-tiles(
            model.media-id,
            model.source-in-s,
            model.source-range.duration.value,
            EditorStore.project.sequence.fps.num,
            EditorStore.project.sequence.fps.den,
            root.zoom,
            root.vis-from-bucket,
            root.vis-to-bucket,
            StripBackend.generation): Image {
            x: tile.x;
            y: 0;
            width: tile.width;
            height: parent.height;
            source: tile.image;
            image-fit: cover;
            // Leaf element: opacity folds into the draw (no layer texture).
            opacity: root.dimmed ? 0.35 : 1.0;
        }
    }

    // Waveform: peak file computed once per media, tiles rasterized per
    // zoom bucket; the raster stretches to the live tile width (≤ 2×).
    if show-waveform: Rectangle {
        for tile in StripBackend.waveform-tiles(
            model.media-id,
            model.source-in-s,
            model.source-range.duration.value,
            EditorStore.project.sequence.fps.num,
            EditorStore.project.sequence.fps.den,
            root.zoom,
            root.vis-from-bucket,
            root.vis-to-bucket,
            StripBackend.generation): Image {
            x: tile.x;
            y: 0;
            width: tile.width;
            height: parent.height;
            source: tile.image;
            image-fit: fill;
            opacity: root.dimmed ? 0.35 : 1.0;
        }
    }

    ta := TouchArea {
        width: parent.width;
        height: parent.height;
        // Locked lanes are read-only: no select / move on their clips.
        enabled: !root.track-locked;

        pointer-event(e) => {
            if (e.kind == PointerEventKind.down && e.button == PointerEventButton.left) {
                // Grabbing a clip reclaims the keyboard so Delete /
                // Ctrl+B act on this selection, not a stale text box.
                AppState.refocus-shortcuts();

                // Shift-click toggles this clip (and its link group) in the
                // multi-selection — selection only, no drag.
                if (e.modifiers.shift) {
                    TimelineStore.apply-selection(SelectionBackend.toggle-clip(
                        EditorStore.project.sequence,
                        TimelineStore.selected-ids,
                        track-id,
                        model.id,
                        TimelineStore.link-enabled));
                    return;
                }

                // Select on grab (CapCut selects the clip the moment you
                // grab it; linkage pulls the clip's partners in). Grabbing
                // a clip already inside a multi-selection keeps the set and
                // re-anchors the primary, so the whole set drags together.
                if (root.is-selected && TimelineStore.selected-ids.length > 1) {
                    TimelineStore.selected-track-id = track-id;
                    TimelineStore.selected-clip-id = model.id;
                } else {
                    TimelineStore.apply-selection(SelectionBackend.select-clip(
                        EditorStore.project.sequence,
                        track-id,
                        model.id,
                        TimelineStore.link-enabled));
                }

                TimelineViewState.drag-is-group = TimelineStore.selected-ids.length > 1;
                TimelineViewState.dragging-source-track-id = track-id;
                TimelineViewState.dragging-clip-id = model.id;
                TimelineViewState.dragging-source-row = track-row;
                TimelineViewState.dragging-start-value = model.timeline-start.value;
                TimelineViewState.dragging-duration-ticks = model.source-range.duration.value;
                TimelineViewState.dragging-color = track-color;
                TimelineViewState.dragging-name = model.name;
                TimelineViewState.drag-dx-px = 0px;
                TimelineViewState.drag-dy-px = 0px;
                TimelineViewState.pointer-window-x = self.absolute-position.x + self.mouse-x;
                TimelineViewState.pointer-window-y = self.absolute-position.y + self.mouse-y;
            } else if (e.kind == PointerEventKind.up
                    && e.button == PointerEventButton.left
                    && is-active-drag) {
                // TimelinePanel commits (if the drag moved) and clears the state.
                TimelineViewState.drag-released = true;
            }
        }

        moved => {
            if (!is-active-drag) {
                return;
            }
            // The element itself never moves, so the totals are just the
            // offsets from the press point.
            TimelineViewState.drag-dx-px = self.mouse-x - self.pressed-x;
            TimelineViewState.drag-dy-px = self.mouse-y - self.pressed-y;
            TimelineViewState.pointer-window-x = self.absolute-position.x + self.mouse-x;
            TimelineViewState.pointer-window-y = self.absolute-position.y + self.mouse-y;
        }
    }

    // Text clips render their generator content inline (Phase 8); the name
    // row above still identifies the lane kind.
    if is-text: Text {
        x: 6px;
        y: root.show-labels ? root.label-row-h : 0;
        width: parent.width - 12px;
        height: parent.height - self.y;
        text: model.text-content == "" ? model.name : model.text-content;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
        // Leaf element: opacity here is folded into the glyph color (no layer).
        opacity: dimmed ? 0.35 : 1.0;
    }

    // Name + duration badge on a thin scrim, CapCut-style — legible over
    // filmstrip frames, harmless on flat cards. (The root clips the corners.)
    if show-labels: Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: root.label-row-h;
        background: dimmed ? #00000020 : #00000059;

        Text {
            x: 4px;
            width: min(self.preferred-width,
                parent.width - (root.width > 90px ? 44px : 8px));
            height: parent.height;
            vertical-alignment: center;
            text: model.name;
            font-size: 9px;
            overflow: elide;
            color: AppStore.theme.text.primary;
            opacity: dimmed ? 0.35 : 1.0;
        }

        // Duration badge (speed/volume markers join it once they exist in
        // the model).
        if root.width > 90px: Text {
            x: parent.width - self.preferred-width - 4px;
            height: parent.height;
            vertical-alignment: center;
            text: model.duration-label;
            font-size: 9px;
            color: AppStore.theme.text.primary.with-alpha(0.75);
            opacity: dimmed ? 0.35 : 1.0;
        }
    }

    // --- trim handles (declared last ⇒ on top of the move TouchArea) -----
    // Like the move, the handle only records the gesture; TimelinePanel
    // resolves the new extent (stretch preview + guide + tooltip) and commits.

    function begin-trim(head: bool) {
        // Select on grab, like the move gesture (and reclaim the keyboard).
        // Linkage pulls the partners in, mirroring the trim that will apply
        // the same edge delta to the whole link group.
        AppState.refocus-shortcuts();
        TimelineStore.apply-selection(SelectionBackend.select-clip(
            EditorStore.project.sequence,
            track-id,
            model.id,
            TimelineStore.link-enabled));

        TimelineViewState.trimming-track-id = track-id;
        TimelineViewState.trimming-clip-id = model.id;
        TimelineViewState.trimming-head = head;
        TimelineViewState.trimming-source-row = track-row;
        TimelineViewState.trimming-duration-ticks = model.source-range.duration.value;
        TimelineViewState.trimming-color = track-color;
        TimelineViewState.trim-dx-px = 0px;
    }

    head-ta := TouchArea {
        x: 0;
        width: root.handle-width;
        height: parent.height;
        mouse-cursor: ew-resize;
        enabled: !root.track-locked;

        changed pressed => {
            if (self.pressed) {
                begin-trim(true);
                TimelineViewState.pointer-window-x = self.absolute-position.x + self.mouse-x;
                TimelineViewState.pointer-window-y = self.absolute-position.y + self.mouse-y;
            } else if (is-active-trim) {
                TimelineViewState.trim-released = true;
            }
        }

        moved => {
            if (is-active-trim) {
                TimelineViewState.trim-dx-px = self.mouse-x - self.pressed-x;
                TimelineViewState.pointer-window-x = self.absolute-position.x + self.mouse-x;
                TimelineViewState.pointer-window-y = self.absolute-position.y + self.mouse-y;
            }
        }
    }

    tail-ta := TouchArea {
        x: parent.width - root.handle-width;
        width: root.handle-width;
        height: parent.height;
        mouse-cursor: ew-resize;
        enabled: !root.track-locked;

        changed pressed => {
            if (self.pressed) {
                begin-trim(false);
                TimelineViewState.pointer-window-x = self.absolute-position.x + self.mouse-x;
                TimelineViewState.pointer-window-y = self.absolute-position.y + self.mouse-y;
            } else if (is-active-trim) {
                TimelineViewState.trim-released = true;
            }
        }

        moved => {
            if (is-active-trim) {
                TimelineViewState.trim-dx-px = self.mouse-x - self.pressed-x;
                TimelineViewState.pointer-window-x = self.absolute-position.x + self.mouse-x;
                TimelineViewState.pointer-window-y = self.absolute-position.y + self.mouse-y;
            }
        }
    }

    // CapCut-style bracket bars hinting the grabbable edges.
    if is-selected || head-ta.has-hover: Rectangle {
        x: 2px;
        width: 2px;
        height: parent.height * 0.5;
        background: AppStore.theme.text.primary;
        border-radius: 1px;
    }
    if is-selected || tail-ta.has-hover: Rectangle {
        x: parent.width - 4px;
        width: 2px;
        height: parent.height * 0.5;
        background: AppStore.theme.text.primary;
        border-radius: 1px;
    }

    // Selection outline, drawn last: a border on the root itself would be
    // painted *under* the filmstrip/waveform tiles and the label scrim.
    if is-selected: Rectangle {
        border-width: 1px;
        border-color: dimmed
            ? AppStore.theme.text.primary.with-alpha(0.35)
            : AppStore.theme.text.primary;
        border-radius: AppStore.theme.track-lane.clip.radius;
    }
}
