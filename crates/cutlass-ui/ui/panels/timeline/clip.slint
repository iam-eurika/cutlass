import { AppStore } from "../../store/index.slint";
import { Clip } from "../../models/index.slint";
import { TimelineLib } from "../../lib/index.slint";
import { TimelineStore } from "../../store/timeline-store.slint";
import { TimelineViewState } from "state.slint";
import { AppState } from "../../state.slint";

// Named `model` because `clip` is a built-in Slint property on visual elements.
//
// The drag gesture only records state here (press snapshot + cursor deltas);
// TimelinePanel owns the resolution, the floating drag visual, the ghost, and
// the commit — the original clip just stays in place, dimmed, until the
// engine republishes the projection.
export component ClipView inherits Rectangle {
    in property <Clip> model;
    in property <string> track-id;
    in property <int> track-row;
    in property <color> track-color;
    in property <float> zoom;

    private property <bool> is-active-drag:
        TimelineViewState.dragging-source-track-id == track-id
        && TimelineViewState.dragging-clip-id == model.id;

    private property <bool> is-active-trim:
        TimelineViewState.trimming-track-id == track-id
        && TimelineViewState.trimming-clip-id == model.id;

    private property <bool> is-selected:
        TimelineStore.selected-track-id == track-id
        && TimelineStore.selected-clip-id == model.id;

    // Edge handles cap at a third of the clip so very short clips keep a
    // grabbable middle for the move gesture.
    private property <length> handle-width: min(6px, self.width / 3);

    // CapCut dims the source position while the floating copy (move) or the
    // stretch preview (trim) shows the live result.
    //
    // Dim via per-element colors, NOT the group `opacity` property: opacity on
    // an element with children makes Slint composite the subtree into an
    // intermediate GPU texture sized to the element's full geometry. A long
    // clip at high zoom exceeds the GPU max texture dimension (16384 px) and
    // aborts the app inside wgpu.
    private property <bool> dimmed: is-active-drag || is-active-trim;

    x: TimelineLib.rational-to-length(model.timeline-start, zoom);

    width: TimelineLib.clip-timeline-width(model, zoom);
    height: AppStore.theme.track-lane.clip.height;
    background: dimmed ? track-color.with-alpha(0.35) : track-color;
    border-radius: AppStore.theme.track-lane.clip.radius;

    border-width: is-selected ? 1px : 0px;
    border-color: dimmed
        ? AppStore.theme.text.primary.with-alpha(0.35)
        : AppStore.theme.text.primary;

    ta := TouchArea {
        width: parent.width;
        height: parent.height;

        changed pressed => {
            if (self.pressed) {
                // Grabbing a clip reclaims the keyboard so Delete /
                // Ctrl+B act on this selection, not a stale text box.
                AppState.refocus-shortcuts();

                // Select on grab (CapCut selects the clip the moment you grab it).
                TimelineStore.selected-track-id = track-id;
                TimelineStore.selected-clip-id = model.id;

                TimelineViewState.dragging-source-track-id = track-id;
                TimelineViewState.dragging-clip-id = model.id;
                TimelineViewState.dragging-source-row = track-row;
                TimelineViewState.dragging-start-value = model.timeline-start.value;
                TimelineViewState.dragging-duration-ticks = model.source-range.duration.value;
                TimelineViewState.dragging-color = track-color;
                TimelineViewState.dragging-name = model.name;
                TimelineViewState.drag-dx-px = 0px;
                TimelineViewState.drag-dy-px = 0px;
            } else if (is-active-drag) {
                // TimelinePanel commits (if the drag moved) and clears the state.
                TimelineViewState.drag-released = true;
            }
        }

        moved => {
            if (!is-active-drag) {
                return;
            }
            // The element itself never moves, so the totals are just the
            // offsets from the press point.
            TimelineViewState.drag-dx-px = self.mouse-x - self.pressed-x;
            TimelineViewState.drag-dy-px = self.mouse-y - self.pressed-y;
        }
    }

    Text {
        text: model.name;
        // Leaf element: opacity here is folded into the glyph color (no layer).
        opacity: dimmed ? 0.35 : 1.0;
    }

    // --- trim handles (declared last ⇒ on top of the move TouchArea) -----
    // Like the move, the handle only records the gesture; TimelinePanel
    // resolves the new extent (stretch preview + guide + tooltip) and commits.

    function begin-trim(head: bool) {
        // Select on grab, like the move gesture (and reclaim the keyboard).
        AppState.refocus-shortcuts();
        TimelineStore.selected-track-id = track-id;
        TimelineStore.selected-clip-id = model.id;

        TimelineViewState.trimming-track-id = track-id;
        TimelineViewState.trimming-clip-id = model.id;
        TimelineViewState.trimming-head = head;
        TimelineViewState.trimming-source-row = track-row;
        TimelineViewState.trimming-duration-ticks = model.source-range.duration.value;
        TimelineViewState.trimming-color = track-color;
        TimelineViewState.trim-dx-px = 0px;
    }

    head-ta := TouchArea {
        x: 0;
        width: root.handle-width;
        height: parent.height;
        mouse-cursor: ew-resize;

        changed pressed => {
            if (self.pressed) {
                begin-trim(true);
            } else if (is-active-trim) {
                TimelineViewState.trim-released = true;
            }
        }

        moved => {
            if (is-active-trim) {
                TimelineViewState.trim-dx-px = self.mouse-x - self.pressed-x;
            }
        }
    }

    tail-ta := TouchArea {
        x: parent.width - root.handle-width;
        width: root.handle-width;
        height: parent.height;
        mouse-cursor: ew-resize;

        changed pressed => {
            if (self.pressed) {
                begin-trim(false);
            } else if (is-active-trim) {
                TimelineViewState.trim-released = true;
            }
        }

        moved => {
            if (is-active-trim) {
                TimelineViewState.trim-dx-px = self.mouse-x - self.pressed-x;
            }
        }
    }

    // CapCut-style bracket bars hinting the grabbable edges.
    if is-selected || head-ta.has-hover: Rectangle {
        x: 2px;
        width: 2px;
        height: parent.height * 0.5;
        background: AppStore.theme.text.primary;
        border-radius: 1px;
    }
    if is-selected || tail-ta.has-hover: Rectangle {
        x: parent.width - 4px;
        width: 2px;
        height: parent.height * 0.5;
        background: AppStore.theme.text.primary;
        border-radius: 1px;
    }
}
