import { CutlassText, HorizontalDivider } from "../../components/index.slint";
import { AppStore, TimelineStore } from "../../store/index.slint";
import { Slider } from "std-widgets.slint";
import { EditorStore } from "../../store/editor-store.slint";

export component Toolbar inherits Rectangle {
    height: AppStore.theme.metrics.layout.toolbar-height;

    CutlassText {
        text: "Tools";
        style: AppStore.theme.typography.label;
    }

    // CapCut's auto-snapping magnet toggle: highlighted while active.
    snap-toggle := Rectangle {
        x: 60px;
        y: 4px;
        width: 52px;
        height: parent.height - 8px;
        border-radius: 4px;
        background: TimelineStore.snap-enabled ? #00E5C766 : transparent;
        border-width: 1px;
        border-color: TimelineStore.snap-enabled ? #00E5C7 : #ffffff40;

        CutlassText {
            text: "Snap";
            style: AppStore.theme.typography.label;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }

        TouchArea {
            clicked => {
                TimelineStore.snap-enabled = !TimelineStore.snap-enabled;
            }
        }
    }

    Slider {
        minimum: 0;
        maximum: 100;
        value: 0;
        step: 1;
        y: 10px;
        x: 150px;
        width: 90%;

        changed(value) => {
            EditorStore.on-slider-changed(value);
        }
    }

    HorizontalDivider {
        y: parent.height - self.height;
    }
}
