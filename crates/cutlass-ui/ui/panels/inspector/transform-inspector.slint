// CapCut's "Basic" transform block (preview roadmap Phase 5): numeric truth
// for what the mouse does in the preview. Value rows show the playhead
// sample of each (possibly animated) property — `sample-transform` re-runs
// per playhead move, no projection republish needed (keyframes roadmap
// Phase 1). Reads live values mid-gesture from PreviewStore (the projection
// is frozen during one), and its own slider drags ride the same
// override-then-commit pipeline as preview gestures — so the preview frame
// and selection box follow the sliders.

import { CutlassText, SubtleButton } from "../../components/index.slint";
import { AppStore, EditorStore, TimelineStore, PreviewStore } from "../../store/index.slint";
import { Clip } from "../../models/index.slint";
import {
    InspectorBackend,
    TransformSample,
} from "../../lib/inspector-backend.slint";
import { SliderRow } from "inspector-widgets.slint";

export component TransformInspector inherits VerticalLayout {
    // Named `model` — `clip` is a built-in boolean on Slint elements.
    in property <Clip> model;

    spacing: AppStore.theme.metrics.spacing.lg;
    alignment: LayoutAlignment.start;

    private property <float> canvas-w: EditorStore.project.sequence.width / 1px;
    private property <float> canvas-h: EditorStore.project.sequence.height / 1px;

    // Playhead sample + per-property keyframe row state, recomputed when
    // the playhead or the projected clip changes.
    private property <TransformSample> sample: InspectorBackend.sample-transform(
        root.model, TimelineStore.playhead-tick);
    // Keyframes may only sit inside the clip (engine rule); gate the
    // diamonds rather than letting the command bounce.
    private property <bool> playhead-inside: TimelineStore.playhead-tick >= root.model.timeline-start.value
        && TimelineStore.playhead-tick < root.model.timeline-start.value + root.model.source-range.duration.value;

    // Mid-gesture the projection still holds committed values; the live
    // resolution is mirrored in PreviewStore by whoever drives the gesture.
    private property <bool> live: PreviewStore.gesture-active
        && PreviewStore.gesture-clip == model.id
        && PreviewStore.gesture.valid;
    private property <float> pos-x: live ? PreviewStore.gesture.position-x : sample.position-x;
    private property <float> pos-y: live ? PreviewStore.gesture.position-y : sample.position-y;
    private property <float> anchor-x: live ? PreviewStore.gesture.anchor-x : sample.anchor-x;
    private property <float> anchor-y: live ? PreviewStore.gesture.anchor-y : sample.anchor-y;
    private property <float> scale-v: live ? PreviewStore.gesture.scale : sample.scale;
    private property <float> rot-v: live ? PreviewStore.gesture.rotation : sample.rotation;
    private property <float> opacity-v: live ? PreviewStore.gesture.opacity : sample.opacity;

    // Transient "keyframe added" chip: the worker bumps the epoch when a
    // transform commit wrote keyframes (gesture on an animated clip — M2
    // compose semantics), which is otherwise easy to miss.
    private property <int> kf-epoch: EditorStore.keyframe-commit-epoch;
    private property <bool> badge-visible: false;

    changed kf-epoch => {
        root.badge-visible = true;
    }

    badge-timer := Timer {
        interval: 2.5s;
        running: root.badge-visible;
        triggered => {
            root.badge-visible = false;
        }
    }

    // One funnel for every row, in normalized model units. Previews render
    // as an uncommitted worker override (no history, projection frozen);
    // commits land one undoable SetClipTransform — unless nothing changed
    // against the playhead sample (slider released without motion, Enter on
    // the same value, reset of an already-default property), which only
    // drops any active override.
    function apply(px: float, py: float, ax: float, ay: float, s: float, r: float, o: float, commit: bool) {
        if (commit) {
            if (px == sample.position-x
                && py == sample.position-y
                && ax == sample.anchor-x
                && ay == sample.anchor-y
                && s == sample.scale
                && r == sample.rotation
                && o == sample.opacity) {
                if (PreviewStore.gesture-active && PreviewStore.gesture-clip == model.id) {
                    EditorStore.on-preview-override-cleared(TimelineStore.playhead-tick);
                }
                PreviewStore.gesture-active = false;
                PreviewStore.gesture-commit-pending = false;
            } else {
                EditorStore.on-clip-transform-committed(
                    model.id, px, py, ax, ay, s, r, o, TimelineStore.playhead-tick);
                PreviewStore.gesture-commit-pending = true;
            }
        } else {
            PreviewStore.gesture-clip = model.id;
            PreviewStore.gesture = {
                valid: true,
                moved: true,
                position-x: px,
                position-y: py,
                anchor-x: ax,
                anchor-y: ay,
                scale: s,
                rotation: r,
                opacity: o,
                snap-h: false,
                snap-v: false,
                guide-x: 0,
                guide-y: 0,
            };
            PreviewStore.gesture-commit-pending = false;
            PreviewStore.gesture-active = true;
            EditorStore.on-preview-transform-overridden(
                model.id, px, py, ax, ay, s, r, o, TimelineStore.playhead-tick);
        }
    }

    // Diamond toggle for one property: on a keyframe ⇒ remove it; anywhere
    // else ⇒ write one at the playhead holding the value currently shown
    // (the sample), so toggling never visibly changes the frame.
    function toggle-kf(param: string, on-keyframe: bool, vx: float, vy: float) {
        if (on-keyframe) {
            InspectorBackend.remove-param-keyframe(model.id, param, TimelineStore.playhead-tick);
        } else {
            InspectorBackend.set-param-keyframe(
                model.id, param, TimelineStore.playhead-tick, vx, vy, 0);
        }
    }

    // Re-ease the keyframe under the playhead: same tick + value (the
    // sample IS the keyframe value there), new outgoing curve.
    function ease-kf(param: string, easing: int, vx: float, vy: float) {
        InspectorBackend.set-param-keyframe(
            model.id, param, TimelineStore.playhead-tick, vx, vy, easing);
    }

    HorizontalLayout {
        spacing: AppStore.theme.metrics.spacing.sm;
        height: 26px;
        vertical-stretch: 0;

        CutlassText {
            text: "Transform ^";
            style: AppStore.theme.typography.heading-sm;
            vertical-alignment: TextVerticalAlignment.center;
        }

        if root.badge-visible: Rectangle {
            border-radius: AppStore.theme.metrics.radius.sm;
            background: AppStore.theme.accent.primary.with-alpha(0.12);

            HorizontalLayout {
                padding-left: AppStore.theme.metrics.spacing.sm;
                padding-right: AppStore.theme.metrics.spacing.sm;
                spacing: AppStore.theme.metrics.spacing.xs;

                Path {
                    width: 7px;
                    height: 100%;
                    viewbox-width: 10;
                    viewbox-height: 10;
                    fill: AppStore.theme.accent.primary;

                    MoveTo { x: 5; y: 0.8; }
                    LineTo { x: 9.2; y: 5; }
                    LineTo { x: 5; y: 9.2; }
                    LineTo { x: 0.8; y: 5; }
                    Close { }
                }

                CutlassText {
                    text: "Keyframe added";
                    style: AppStore.theme.typography.caption;
                    foreground: AppStore.theme.accent.primary;
                    vertical-alignment: TextVerticalAlignment.center;
                }
            }
        }

        Rectangle {
            horizontal-stretch: 1;
        }

        // Fit/fill helpers (M1 canvas settings): center the clip at
        // aspect-fit scale, or at the cover scale that fills the canvas.
        // One undoable transform commit each; the worker computes the
        // cover scale from media dims × crop vs the canvas.
        SubtleButton {
            label: "Fit";
            clicked => {
                InspectorBackend.fit-clip(model.id, false, TimelineStore.playhead-tick);
            }
        }

        SubtleButton {
            label: "Fill";
            clicked => {
                InspectorBackend.fit-clip(model.id, true, TimelineStore.playhead-tick);
            }
        }
    }

    SliderRow {
        label: "Position X";
        suffix: "px";
        value: root.pos-x * root.canvas-w;
        minimum: -root.canvas-w;
        maximum: root.canvas-w;
        reset-value: 0;
        kf-visible: true;
        kf: root.sample.position-row;
        kf-can-toggle: root.playhead-inside;
        preview(v) => {
            root.apply(v / root.canvas-w, root.pos-y, root.anchor-x, root.anchor-y, root.scale-v, root.rot-v, root.opacity-v, false);
        }
        commit(v) => {
            root.apply(v / root.canvas-w, root.pos-y, root.anchor-x, root.anchor-y, root.scale-v, root.rot-v, root.opacity-v, true);
        }
        // Position is one vec2 param: either axis row keyframes both.
        kf-toggle => {
            root.toggle-kf("position", root.sample.position-row.on-keyframe, root.pos-x, root.pos-y);
        }
        kf-set-easing(e) => {
            root.ease-kf("position", e, root.pos-x, root.pos-y);
        }
    }

    SliderRow {
        label: "Position Y";
        suffix: "px";
        value: root.pos-y * root.canvas-h;
        minimum: -root.canvas-h;
        maximum: root.canvas-h;
        reset-value: 0;
        kf-visible: true;
        kf: root.sample.position-row;
        kf-can-toggle: root.playhead-inside;
        preview(v) => {
            root.apply(root.pos-x, v / root.canvas-h, root.anchor-x, root.anchor-y, root.scale-v, root.rot-v, root.opacity-v, false);
        }
        commit(v) => {
            root.apply(root.pos-x, v / root.canvas-h, root.anchor-x, root.anchor-y, root.scale-v, root.rot-v, root.opacity-v, true);
        }
        kf-toggle => {
            root.toggle-kf("position", root.sample.position-row.on-keyframe, root.pos-x, root.pos-y);
        }
        kf-set-easing(e) => {
            root.ease-kf("position", e, root.pos-x, root.pos-y);
        }
    }

    SliderRow {
        label: "Anchor X";
        suffix: "%";
        value: root.anchor-x * 100;
        minimum: 0;
        maximum: 100;
        reset-value: 50;
        kf-visible: true;
        kf: root.sample.anchor-row;
        kf-can-toggle: root.playhead-inside;
        preview(v) => {
            root.apply(root.pos-x, root.pos-y, v / 100, root.anchor-y, root.scale-v, root.rot-v, root.opacity-v, false);
        }
        commit(v) => {
            root.apply(root.pos-x, root.pos-y, v / 100, root.anchor-y, root.scale-v, root.rot-v, root.opacity-v, true);
        }
        kf-toggle => {
            root.toggle-kf("anchor", root.sample.anchor-row.on-keyframe, root.anchor-x, root.anchor-y);
        }
        kf-set-easing(e) => {
            root.ease-kf("anchor", e, root.anchor-x, root.anchor-y);
        }
    }

    SliderRow {
        label: "Anchor Y";
        suffix: "%";
        value: root.anchor-y * 100;
        minimum: 0;
        maximum: 100;
        reset-value: 50;
        kf-visible: true;
        kf: root.sample.anchor-row;
        kf-can-toggle: root.playhead-inside;
        preview(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, v / 100, root.scale-v, root.rot-v, root.opacity-v, false);
        }
        commit(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, v / 100, root.scale-v, root.rot-v, root.opacity-v, true);
        }
        kf-toggle => {
            root.toggle-kf("anchor", root.sample.anchor-row.on-keyframe, root.anchor-x, root.anchor-y);
        }
        kf-set-easing(e) => {
            root.ease-kf("anchor", e, root.anchor-x, root.anchor-y);
        }
    }

    SliderRow {
        label: "Scale";
        suffix: "%";
        value: root.scale-v * 100;
        // Engine validation requires a positive scale; floor numeric entry
        // at 1% too.
        minimum: 1;
        maximum: 400;
        reset-value: 100;
        kf-visible: true;
        kf: root.sample.scale-row;
        kf-can-toggle: root.playhead-inside;
        preview(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, max(v, 1) / 100, root.rot-v, root.opacity-v, false);
        }
        commit(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, max(v, 1) / 100, root.rot-v, root.opacity-v, true);
        }
        kf-toggle => {
            root.toggle-kf("scale", root.sample.scale-row.on-keyframe, root.scale-v, 0);
        }
        kf-set-easing(e) => {
            root.ease-kf("scale", e, root.scale-v, 0);
        }
    }

    SliderRow {
        label: "Rotation";
        suffix: "°";
        value: root.rot-v;
        minimum: -180;
        maximum: 180;
        reset-value: 0;
        kf-visible: true;
        kf: root.sample.rotation-row;
        kf-can-toggle: root.playhead-inside;
        preview(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-v, v, root.opacity-v, false);
        }
        commit(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-v, v, root.opacity-v, true);
        }
        kf-toggle => {
            root.toggle-kf("rotation", root.sample.rotation-row.on-keyframe, root.rot-v, 0);
        }
        kf-set-easing(e) => {
            root.ease-kf("rotation", e, root.rot-v, 0);
        }
    }

    SliderRow {
        label: "Opacity";
        suffix: "%";
        value: root.opacity-v * 100;
        minimum: 0;
        maximum: 100;
        reset-value: 100;
        kf-visible: true;
        kf: root.sample.opacity-row;
        kf-can-toggle: root.playhead-inside;
        preview(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-v, root.rot-v, clamp(v, 0, 100) / 100, false);
        }
        commit(v) => {
            root.apply(root.pos-x, root.pos-y, root.anchor-x, root.anchor-y, root.scale-v, root.rot-v, clamp(v, 0, 100) / 100, true);
        }
        kf-toggle => {
            root.toggle-kf("opacity", root.sample.opacity-row.on-keyframe, root.opacity-v, 0);
        }
        kf-set-easing(e) => {
            root.ease-kf("opacity", e, root.opacity-v, 0);
        }
    }
}
