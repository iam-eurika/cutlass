import { TrackKind } from "models/index.slint";

// App-wide window/view state. Anything that affects the whole shell
// (chrome visibility, full-window overlays, …) lives here rather than
// inside any one panel's state global.
export global AppState {
    in-out property <bool> preview-maximized: false;

    // AI assistant chat panel (ai-agent roadmap Phase 4): docked at the
    // far right, toggled from the title bar.
    in-out property <bool> agent-panel-open: false;

    // Export settings dialog (modal overlay; see shell/export-dialog.slint).
    in-out property <bool> export-dialog-open: false;

    // Bumped to pull keyboard focus back to the window's shortcut
    // FocusScope (app.slint watches it). Text inputs legitimately take
    // focus while editing; timeline interactions (clip grab, lane
    // click, ruler scrub) call this so Delete / Ctrl+B / … always act
    // on the timeline right after a click — never on a stale text box.
    in-out property <int> shortcut-focus-nonce: 0;

    public function refocus-shortcuts() {
        self.shortcut-focus-nonce += 1;
    }

    // Window-space ghost while dragging a library tile onto the timeline.
    in-out property <bool> library-drag-active: false;
    // Identity + length (sequence ticks) of the media being dragged — set at
    // press, consumed by the timeline's drop handler.
    in-out property <string> library-drag-media-id: "";
    in-out property <int> library-drag-duration-ticks: 0;
    // Lane kind the dragged tile targets: video for media, text/sticker for
    // generated tiles. Drives the kind-aware drop resolver (src/snap.rs).
    in-out property <TrackKind> library-drag-lane-kind: TrackKind.video;
    // Generator catalog key for a generated-tile drag ("text" | "solid" |
    // "rect" | "ellipse"); "" while dragging imported media. Selects which
    // drop callback the timeline fires on release.
    in-out property <string> library-drag-generator: "";
    in-out property <length> library-drag-w: 0px;
    in-out property <length> library-drag-h: 0px;
    // Cursor offset within the library tile at press — used to anchor the square ghost.
    in-out property <length> library-drag-tile-anchor-x: 0px;
    in-out property <length> library-drag-tile-anchor-y: 0px;

    // Cursor point in window coords during the drag. Drop targeting keys off
    // the pointer, not the ghost rectangle's corner.
    in-out property <length> library-drag-cursor-x: 0px;
    in-out property <length> library-drag-cursor-y: 0px;

    // Written by TimelinePanel (it knows its own window-space bounds); read by
    // the library's drop handler and the ghost.
    in-out property <bool> library-drag-over-timeline: false;
}
