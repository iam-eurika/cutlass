// Full-window preview overlay. Rendered in place of the normal editor
// shell while `AppState.preview-maximized` is true. The host window
// itself is just maximized (chrome stays); this component only handles
// the in-window layout: a letterboxed preview plus a floating transport
// bar that auto-hides after mouse idle (CapCut-style).
import { AppState } from "state.slint";
import { AppStore } from "store/index.slint";
import { EditorStore, TimelineStore, PreviewStore, TimelineActions } from "store/index.slint";
import { TimelineLib } from "lib/timeline-lib.slint";
import { RationalTime } from "models/index.slint";
import { Slider } from "std-widgets.slint";

export component FullscreenPreview inherits Rectangle {
    private property <RationalTime> sequence-duration:
        TimelineLib.sequence-duration(EditorStore.project.sequence);
    private property <float> sequence-aspect-ratio:
        EditorStore.project.sequence.width / EditorStore.project.sequence.height;
    private property <bool> controls-visible: true;
    private property <bool> bar-hovered: bar-ta.has-hover;

    // Idle is measured by polling a fixed-interval Timer rather than
    // trying to restart a one-shot. Restarting a Slint Timer by toggling
    // `running` does not reliably reset the next-fire instant (see
    // slint-ui/slint#6369), which previously caused the bar to flicker
    // hide/show during active mouse movement.
    private property <int> ticks-since-activity: 0;
    private property <int> idle-tick-threshold: 13; // ~2.6s @ 200ms tick

    idle-tick := Timer {
        interval: 200ms;
        running: true;
        triggered => {
            if (root.bar-hovered) {
                root.ticks-since-activity = 0;
            } else {
                root.ticks-since-activity += 1;
                if (root.ticks-since-activity >= root.idle-tick-threshold) {
                    root.controls-visible = false;
                }
            }
        }
    }

    function note-activity() {
        root.controls-visible = true;
        root.ticks-since-activity = 0;
    }

    changed bar-hovered => {
        if (root.bar-hovered) {
            root.controls-visible = true;
            root.ticks-since-activity = 0;
        }
    }

    // The seek slider's handle follows the playhead through this watcher
    // (and the init below for the position on entry) — see seek-slider for
    // why it can't be a `value` binding.
    private property <int> slider-playhead: TimelineStore.playhead-tick;

    changed slider-playhead => {
        seek-slider.value = root.sequence-duration.value > 0
            ? 100 * root.slider-playhead / root.sequence-duration.value
            : 0;
    }

    init => {
        seek-slider.value = root.sequence-duration.value > 0
            ? 100 * TimelineStore.playhead-tick / root.sequence-duration.value
            : 0;
    }

    background: AppStore.theme.panel.background;

    // Catches movement in letterbox padding (areas outside the preview).
    TouchArea {
        width: 100%;
        height: 100%;
        enabled: root.controls-visible;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.move) {
                root.note-activity();
            }
        }
    }

    // Letterboxed preview surface, sized to the sequence aspect ratio.
    Rectangle {
        width: min(parent.width, parent.height * root.sequence-aspect-ratio);
        height: self.width / root.sequence-aspect-ratio;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        background: black;

        // Live preview frames — the same worker-delivered image as the
        // docked panel (the playhead → frame-request watcher lives at
        // window scope, so playback keeps rendering in fullscreen).
        Image {
            width: parent.width;
            height: parent.height;
            source: PreviewStore.frame;
            image-fit: ImageFit.contain;
        }

        TouchArea {
            width: 100%;
            height: 100%;
            enabled: root.controls-visible;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.move) {
                    root.note-activity();
                }
            }
        }
    }

    // Floating transport bar pinned to the bottom of the window.
    Rectangle {
        height: 45px;
        width: 580px;
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 65px;

        opacity: root.controls-visible ? 1 : 0;
        animate opacity {
            duration: 250ms;
            easing: ease-out;
        }

        background: #141414;
        border-color: #282828;
        border-width: 1px;
        border-radius: 6px;
        clip: true;

        bar-ta := TouchArea {
            width: 100%;
            height: 100%;
            enabled: root.controls-visible;
            pointer-event(e) => {
                if (e.kind == PointerEventKind.move || e.kind == PointerEventKind.down) {
                    root.note-activity();
                }
            }
        }

        // Play/pause: same TimelineActions path as Space and the docked
        // panel button, so gating can never diverge.
        Image {
            source: TimelineStore.playing
                ? @image-url("assets/icon/pause.svg")
                : @image-url("assets/icon/play.svg");
            image-fit: ImageFit.contain;
            colorize: #ffffff;

            width: 20px;
            height: 20px;
            x: 20px;
            y: (parent.height - self.height) / 2;

            TouchArea {
                enabled: root.controls-visible;
                clicked => {
                    root.note-activity();
                    TimelineActions.toggle-play();
                }
            }
        }

        Text {
            text: TimelineLib.format-timecode(
                TimelineStore.playhead-tick,
                EditorStore.project.sequence.fps.num,
                EditorStore.project.sequence.fps.den,
                EditorStore.project.sequence.drop-frame,
            );
            font-size: 12px;
            font-weight: 600;
            color: #ffffff;
            horizontal-alignment: TextHorizontalAlignment.center;
            vertical-alignment: TextVerticalAlignment.center;

            width: 115px;
            height: parent.height;
            x: 58px;
            y: 0px;
        }

        Text {
            text: "/";
            font-size: 16px;
            font-weight: 700;
            color: #484848;
            horizontal-alignment: TextHorizontalAlignment.center;
            vertical-alignment: TextVerticalAlignment.center;

            width: 16px;
            height: parent.height;
            x: 160px;
            y: 0px;
        }

        Text {
            text: TimelineLib.format-timecode(
                root.sequence-duration.value,
                root.sequence-duration.rate.num,
                root.sequence-duration.rate.den,
                EditorStore.project.sequence.drop-frame,
            );
            font-size: 12px;
            font-weight: 600;
            color: #ffffff;
            horizontal-alignment: TextHorizontalAlignment.center;
            vertical-alignment: TextVerticalAlignment.center;

            width: 115px;
            height: parent.height;
            x: 170px;
            y: 0px;
        }

        // Seek slider (percent of duration). The handle follows the
        // playhead via the watcher below rather than a `value` binding:
        // the Slider assigns `value` internally on drag, which would
        // permanently drop a binding. `changed` only fires from user
        // interaction, so the watcher can't loop; a seek mid-playback
        // re-anchors the transport clock (TimelineActions.playback-step).
        seek-slider := Slider {
            minimum: 0;
            maximum: 100;
            value: 0;

            height: 10px;
            width: 170px;
            x: 330px;
            y: (parent.height - self.height) / 2;

            changed(value) => {
                root.note-activity();
                TimelineStore.playhead-tick = Math.round(
                    value / 100 * root.sequence-duration.value);
            }
        }

        Rectangle {
            height: 15px;
            width: 1px;
            background: #787878;
            x: 520px;
            y: (parent.height - self.height) / 2;
        }

        Image {
            source: @image-url("assets/icon/fullscreen.svg");
            image-fit: ImageFit.contain;
            colorize: #ffffff;

            width: 20px;
            height: 20px;
            x: 545px;
            y: (parent.height - self.height) / 2;

            TouchArea {
                width: 100%;
                height: 100%;
                enabled: root.controls-visible;
                clicked => {
                    AppState.preview-maximized = false;
                }
            }
        }
    }

    // When controls are hidden, sit on top to detect movement without
    // blocking the transport bar while it is visible.
    TouchArea {
        width: 100%;
        height: 100%;
        enabled: !root.controls-visible;
        mouse-cursor: none;
        pointer-event(e) => {
            if (e.kind == PointerEventKind.move || e.kind == PointerEventKind.down) {
                root.note-activity();
            }
        }
    }
}
