import { Project } from "../models/index.slint";

// Slint-side view model. This is a read-only projection of the engine's
// project: the worker thread publishes a fresh `project` (built in
// `src/projection.rs`) on startup and after every mutation. The default below
// is just an empty placeholder shown for the brief moment before the first
// projection arrives — keep `width`/`height` non-zero so preview aspect-ratio
// math never divides by zero.
export global EditorStore {
    callback on-slider-changed(value: float);
    callback on-import-clicked();
    // A library tile was dropped on the timeline. `track-id` is the video lane
    // under the cursor, or empty when there is none — the engine then creates
    // a new video track at `drop-row` (the lane-list row under the cursor; may
    // be out of range, meaning above/below the existing lanes). Drops that
    // overlap clips on the targeted lane slide right into the first gap that
    // fits.
    callback on-clip-dropped(media-id: string, track-id: string, start-tick: int, drop-row: int);
    // A clip drag-move was released. `track-id` names the destination lane,
    // or is empty when a new lane of the clip's kind must be inserted at
    // `insert-row` (lane-list row, top-first). The position was already
    // validated by the drag resolver (no overlap, kind-compatible).
    callback on-clip-moved(clip-id: string, track-id: string, insert-row: int, start-tick: int);
    // An edge-trim drag was released: re-place the clip at
    // `[start-tick, start-tick + duration-ticks)` on its own lane. Already
    // validated by the trim resolver (neighbors, source headroom, ≥ 1 tick).
    callback on-clip-trimmed(clip-id: string, start-tick: int, duration-ticks: int);

    in-out property <Project> project: {
        id: "",
        title: "",
        sequence: {
            id: "",
            name: "",
            fps: { num: 24, den: 1 },
            drop-frame: false,
            width: 1920px,
            height: 1080px,
            tracks: [],
        },
        media: [],
    };
}
