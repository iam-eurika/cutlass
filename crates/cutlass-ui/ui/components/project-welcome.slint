// Fresh-session lifecycle entry points shared by empty editor surfaces.

import { AppStore, EditorStore } from "../store/index.slint";
import { AccentButton, SubtleButton } from "button.slint";
import { CutlassText } from "text.slint";

export component ProjectWelcome inherits Rectangle {
    background: transparent;

    VerticalLayout {
        alignment: center;
        padding: AppStore.theme.metrics.spacing.xl;

        HorizontalLayout {
            alignment: center;

            VerticalLayout {
                width: min(parent.width, 520px);
                spacing: AppStore.theme.metrics.spacing.md;
                alignment: start;

                CutlassText {
                    text: "Get started";
                    style: AppStore.theme.typography.heading-sm;
                    horizontal-alignment: center;
                }

                CutlassText {
                    text: "Create something new, or pick up where you left off.";
                    style: AppStore.theme.typography.caption;
                    foreground: AppStore.theme.text.secondary;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: AppStore.theme.metrics.spacing.sm;
                    alignment: center;

                    AccentButton {
                        label: "New project";
                        clicked => {
                            EditorStore.on-new-requested();
                        }
                    }

                    SubtleButton {
                        label: "Open project";
                        clicked => {
                            EditorStore.on-open-requested();
                        }
                    }
                }

                if EditorStore.recent-projects.length > 0: VerticalLayout {
                    padding-top: AppStore.theme.metrics.spacing.md;
                    spacing: AppStore.theme.metrics.spacing.xs;

                    CutlassText {
                        text: "Recent projects";
                        style: AppStore.theme.typography.label;
                        foreground: AppStore.theme.text.secondary;
                    }

                    for entry in EditorStore.recent-projects: Rectangle {
                        height: 44px;
                        border-radius: AppStore.theme.metrics.radius.sm;
                        background: row-ta.has-hover
                            ? AppStore.theme.surface.content-background
                            : transparent;

                        row-ta := TouchArea {
                            clicked => {
                                EditorStore.on-open-recent-requested(entry.path);
                            }
                        }

                        VerticalLayout {
                            padding-left: AppStore.theme.metrics.spacing.sm;
                            padding-right: AppStore.theme.metrics.spacing.sm;
                            alignment: center;
                            spacing: 2px;

                            CutlassText {
                                text: entry.name;
                                style: AppStore.theme.typography.body;
                                overflow: elide;
                            }

                            CutlassText {
                                text: entry.path;
                                style: AppStore.theme.typography.label;
                                foreground: AppStore.theme.text.secondary;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}
