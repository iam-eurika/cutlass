// Shared drag-and-drop prototype state. Library tiles write pointer
// position while dragging; the timeline panel publishes its window-space
// bounds so we can highlight the drop zone without experimental DragArea.

export global DragState {
    in-out property <bool> active;
    in-out property <length> x;
    in-out property <length> y;
    in-out property <bool> over-timeline;

    in-out property <length> timeline-x;
    in-out property <length> timeline-y;
    in-out property <length> timeline-width;
    in-out property <length> timeline-height;
}
