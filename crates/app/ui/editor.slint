// Cutlass editor shell — composition only. Split logic lives in `components/split_grips.slint`.

import { EditorHeader } from "./components/editor_header.slint";
import { PlaceholderPane } from "./components/placeholder_pane.slint";
import { PreviewPanel } from "./components/preview_panel.slint";
import { TimelinePanel } from "./components/timeline/timeline.slint";
import {
    HSplitGripLead,
    HSplitGripTrail,
    VSplitGripTimeline,
} from "./components/split_grips.slint";
import { LibraryPane } from "./components/library/library.slint";
import { DragGhost } from "./components/drag_ghost.slint";
import { DragState } from "./models/drag_state.slint";

export * from "./models/index.slint";
export { TimelineState } from "./components/timeline/state.slint";

export component EditorWindow inherits Window {
    title: "Cutlass";
    preferred-width: 1280px;
    preferred-height: 800px;

    in-out property <length> left-pane-width: 260px;
    in-out property <length> right-pane-width: 300px;
    in-out property <length> timeline-height: 300px;

    vertical-stretch: 1;

    Rectangle {
        background: #28282a;

        vertical-stretch: 1;

        VerticalLayout {
            spacing: 0px;

            EditorHeader {
                title: "Cutlass";
            }

            Rectangle {
                vertical-stretch: 1;

                HorizontalLayout {
                    spacing: 0px;

                    LibraryPane {
                        width: root.left-pane-width;
                        horizontal-stretch: 0;
                    }

                    HSplitGripLead {
                        pane-width <=> root.left-pane-width;
                    }

                    PreviewPanel {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                    }

                    HSplitGripTrail {
                        pane-width <=> root.right-pane-width;
                    }

                    PlaceholderPane {
                        title: "Inspector";
                        width: root.right-pane-width;
                        horizontal-stretch: 0;
                    }
                }
            }

            VSplitGripTimeline {
                timeline-height <=> root.timeline-height;
            }

            TimelinePanel {
                height: root.timeline-height;
                horizontal-stretch: 1;
            }
        }

        if DragState.active: DragGhost { }

        // Full-window grab while dragging so pointer-up is caught even when
        // the cursor leaves the library tile mid-drag.
        if DragState.active: TouchArea {
            width: 100%;
            height: 100%;

            moved => {
                DragState.x = self.mouse-x;
                DragState.y = self.mouse-y;
                DragState.over-timeline = self.mouse-x >= DragState.timeline-x && self.mouse-x < DragState.timeline-x + DragState.timeline-width && self.mouse-y >= DragState.timeline-y && self.mouse-y < DragState.timeline-y + DragState.timeline-height;
            }

            pointer-event(event) => {
                if (event.kind == PointerEventKind.up && event.button == PointerEventButton.left) {
                    DragState.active = false;
                    DragState.over-timeline = false;
                }
            }
        }
    }
}
