import { AppState } from "../../models/app_state.slint";
import { MediaKind, MediaSource } from "../../models/project.slint";
import { GridView } from "../grid_view.slint";

// One cell in the library grid. Renders the source's thumbnail when one
// is attached, falling back to a kind-tinted placeholder so the user can
// still tell video/audio/image apart while the engine is still probing.
//
// The tile is sized by the parent `GridView` via `x` / `y` / `width` /
// `height` bindings — there is no intrinsic size on this component.
component LibraryTile {
    in property <MediaSource> source;

    frame := Rectangle {
        width: 100%;
        height: 100%;
        background: #38383a;
        border-radius: 4px;
        border-width: source.is-missing ? 1px : 0px;
        border-color: #c2453a;
        clip: true;
        opacity: source.is-loading ? 0.55 : 1.0;

        VerticalLayout {
            spacing: 0px;

            Rectangle {
                vertical-stretch: 1;
                background: source.kind == MediaKind.video ? #2a3a4a : source.kind == MediaKind.audio ? #3a2a3e : #3a3a2a;

                if source.thumbnail.width > 0: Image {
                    source: source.thumbnail;
                    image-fit: cover;
                    width: 100%;
                    height: 100%;
                }
            }

            Rectangle {
                height: 22px;
                background: #00000055;

                Text {
                    text: source.name;
                    color: source.is-missing ? #ff8a80 : #e6e6ec;
                    font-size: 11px;
                    overflow: elide;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    x: 6px;
                    width: parent.width - 12px;
                }
            }
        }

        ta := TouchArea {

            pointer-event(event) => {
                if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                    debug(self.pressed-x);
                    debug(self.pressed-y);
                }
            }

            moved() => {
                if (!self.pressed) {
                    return;
                }
                debug(self.mouse-x);
                debug(self.mouse-y);
            }
        }
    }
}

// Small "+" affordance in the pane header. Mirrors the import action of the
// empty-state region so the user can always trigger import without first
// clearing the bin.
component AddMediaButton inherits Rectangle {
    width: 22px;
    height: 22px;
    border-radius: 4px;
    background: ta.pressed ? #5b6eff : ta.has-hover ? #4a4a55 : #38383a;
    animate background {
        duration: 80ms;
        easing: ease-out;
    }

    Text {
        text: "+";
        color: #d0d0da;
        font-size: 18px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => {
            AppState.import-media()
        }
    }
}

export component LibraryPane inherits Rectangle {
    background: #28282a;
    clip: true;
    in property <int> columns: 3;
    in property <length> tile-size: 100px;
    in property <length> tile-spacing: 10px;

    VerticalLayout {
        padding: 10px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 6px;

            Text {
                text: "Library";
                color: #8e8e98;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            AddMediaButton { }
        }

        // Stack: GridView underneath, empty-state overlay on top. The
        // GridView is always rendered so toggling between empty/non-empty
        // doesn't churn the layout chain (which is what locks Slint's
        // root window when fixed-size children appear inside an `if`).
        Rectangle {
            vertical-stretch: 1;

            grid := GridView {
                width: 100%;
                height: 100%;
                columns: root.columns;
                cell-width: root.tile-size;
                cell-height: root.tile-size;
                spacing: root.tile-spacing;
                item-count: AppState.project.media-bin.length;

                // TODO: uncomment this manually later.

                // for source[i] in AppState.project.media-bin: LibraryTile {
                //     x: grid.cell-x(i);
                //     y: grid.cell-y(i);
                //     width: grid.cell-width;
                //     height: grid.cell-height;
                //     source: source;
                // }

                for i in 20: LibraryTile {
                    x: grid.cell-x(i);
                    y: grid.cell-y(i);
                    width: grid.cell-width;
                    height: grid.cell-height;
                }
            }

            // TODO: uncomment this manually later.
            // 
            // Empty-state click target. Doubles as a click target so a
            // fresh project can start an import without hunting for the
            // small `+` glyph above. Sits on top of `grid` in z-order so
            // the import callback wins over a stray grid click while the
            // bin is empty.
            // if AppState.project.media-bin.length == 0: TouchArea {
            //     width: 100%;
            //     height: 100%;
            //     mouse-cursor: pointer;
            //     clicked => {
            //         AppState.import-media()
            //     }

            //     VerticalLayout {
            //         width: 100%;
            //         height: 100%;
            //         alignment: center;
            //         spacing: 4px;

            //         Text {
            //             text: "No media yet";
            //             color: #5a5a64;
            //             font-size: 12px;
            //             horizontal-alignment: center;
            //         }

            //         Text {
            //             text: "Click to import";
            //             color: #7a7a8a;
            //             font-size: 11px;
            //             horizontal-alignment: center;
            //         }
            //     }
            // }
        }
    }
}
