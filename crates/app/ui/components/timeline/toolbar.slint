import { Slider } from "std-widgets.slint";
import { TimelineState } from "./state.slint";

export component Toolbar inherits Rectangle {
    height: 28px;
    horizontal-stretch: 1;

    HorizontalLayout {
        Text {
            text: "Timeline Tools";
            horizontal-alignment: TextHorizontalAlignment.center;
            vertical-alignment: TextVerticalAlignment.center;
            color: #8e8e98;
            font-size: 12px;
            font-weight: 500;
        }

        // Zoom slider with quadratic mapping: slider value [1, 100] -> zoom
        // [1, 10000] px/sec. Quadratic gives smooth control across the wide
        // useful range (zoom ~1 for hour-long overview, ~250+ for frame mode,
        // multi-thousand for per-frame ticks). The minimum > 0 also guards
        // the ruler picker against div-by-zero / sub-pixel tick spacing.
        Slider {
            width: 200px;
            minimum: 1;
            maximum: 100;
            value: sqrt(TimelineState.zoom);
            step: 1;
            orientation: Orientation.horizontal;

            changed(value) => {
                TimelineState.zoom = max(1.0, value * value);
            }
        }
    }
}
