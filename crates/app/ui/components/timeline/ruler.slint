
import { TimelineState } from "./state.slint";

export component Ruler inherits Rectangle {
    height: 24px;

    property <length> minor-spacing: 20px;
    property <int> major-every: 5;
    property <int> tick-count: max(1, ceil(self.width / minor-spacing));

    // Edge auto-scroll while dragging (NLE-style): pointer may stop moving at the
    // viewport edge, but scroll continues until release or the pointer leaves the zone.
    property <length> edge-margin: 5px;
    property <int> edge-direction: 0; // -1 = left, 0 = none, 1 = right

    edge-timer := Timer {
        interval: 32ms;
        running: root.edge-direction != 0;

        triggered() => {
            if (root.edge-direction < 0) {
                debug("edge-scroll tick ←");
                debug(TimelineState.scroll-x);
                // TimelineState.scroll-x = max(0px, TimelineState.scroll-x + 1px);
            } else if (root.edge-direction > 0) {
                debug("edge-scroll tick →");
                debug(TimelineState.scroll-x);
                // TimelineState.scroll-x = min(TimelineState.viewport-width, TimelineState.scroll-x - 1px);
            }
        }
    }

    for idx in tick-count: Rectangle {
        property <bool> major: mod(idx, major-every) == 0;
        x: idx * minor-spacing;
        y: 2px;
        width: major ? 1.2px : 1px;
        height: major ? 12px : 6px;
        background: major ? #5b5b5b : #464646;
    }

    for idx in tick-count: Text {
        visible: mod(idx, major-every) == 0;
        x: idx * minor-spacing + 5px;
        y: 3.5px;
        text: "\{idx / major-every}";
        color: #5b5b5b;
        font-size: 9px;
        font-weight: 700;
    }

    ta := TouchArea {
        width: 100%;
        height: 100%;

        property <length> drag-start-playhead-x;
        property <length> drag-origin-root-x;

        pointer-event(event) => {
            if (event.kind == PointerEventKind.down && event.button == PointerEventButton.left) {
                TimelineState.playhead-x = min(TimelineState.viewport-width, self.pressed-x);
                self.drag-start-playhead-x = TimelineState.playhead-x;
                self.drag-origin-root-x = self.absolute-position.x + self.pressed-x;
                update-edge-scroll();
            }
            if (event.kind == PointerEventKind.up || event.kind == PointerEventKind.cancel) {
                if (root.edge-direction != 0) {
                    debug("edge-scroll stop");
                }
                root.edge-direction = 0;
            }
        }

        moved() => {
            if (!self.pressed) {
                return;
            }
            let drag-distance = self.drag-start-playhead-x + self.absolute-position.x + self.mouse-x - self.drag-origin-root-x;
            TimelineState.playhead-x = max(0px, min(TimelineState.viewport-width, drag-distance));
            update-edge-scroll();
        }

        function update-edge-scroll() {
            if (!self.pressed) {
                root.edge-direction = 0;
                return;
            }
            if (self.mouse-x < root.edge-margin) {
                if (root.edge-direction != -1) {
                    // debug("edge-scroll zone ←", self.mouse-x);
                }
                root.edge-direction = -1;
            } else if (self.mouse-x > self.width - root.edge-margin) {
                if (root.edge-direction != 1) {
                    // debug("edge-scroll zone →", self.mouse-x);
                }
                root.edge-direction = 1;
            } else if (root.edge-direction != 0) {
                // debug("edge-scroll leave zone");
                root.edge-direction = 0;
            }
        }
    }
}
