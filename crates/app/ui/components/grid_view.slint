// A scrollable, fixed-cell grid view tuned for content bins (media
// library, recents, asset pickers, …).
//
// Why not `GridLayout`
// --------------------
// Slint's built-in `GridLayout` propagates child size constraints up to
// its window: a `for` loop of fixed-height tiles becomes a hard
// max-height on the parent window. After the first import in a fresh
// project the library bin flips from "no tiles" to "1+ tiles", and the
// window snaps to the grid's collapsed preferred height — and then
// refuses to resize because min == max.  GridLayout also panics with
// `RepeatedItemTree::grid_layout_input_data() not implemented for …
// InnerComponent__Opacity_N` whenever a repeated child's root has an
// `opacity` / clip / transform binding (which is anything you'd
// reasonably want for a "loading" or "selected" state).
//
// We sidestep both by placing children absolutely inside a Flickable
// and driving the scrollable extent from `item-count` rather than from
// child constraint propagation.
//
// Tradeoffs
// ---------
// * Uniform cell dimensions. Library bins want one tile size; supporting
//   per-cell sizing would buy us GridLayout's complexity back.
// * Caller passes `item-count` explicitly. Slint can't introspect a
//   `for` loop from inside a sub-component, so we mirror `model.length`
//   in one extra binding (one line) for the win of stable layout.
// * Column count is the API contract, not a side effect of how wide
//   the panel happens to be. When the panel is narrower than
//   `columns * cell-width + …`, the Flickable scrolls horizontally
//   rather than reflowing or clipping tiles.
//
// Usage
// -----
//     grid := GridView {
//         columns: 3;
//         cell-width: 100px;
//         cell-height: 100px;
//         spacing: 10px;
//         item-count: AppState.project.media-bin.length;
//
//         for source[i] in AppState.project.media-bin: LibraryTile {
//             x: grid.cell-x(i);
//             y: grid.cell-y(i);
//             width: grid.cell-width;
//             height: grid.cell-height;
//             source: source;
//         }
//     }
//
// Bind via the element alias (`grid := …`) rather than `parent.cell-x`
// — repeated children placed through `@children` resolve `parent` to
// the inner Flickable, not the GridView, so `parent.cell-x(i)` would
// fail to compile. The alias is unambiguous and reads well.
//
// Defaults
// --------
// `horizontal-stretch: 1`, `vertical-stretch: 1`. Dropped into a layout
// or a non-layout Rectangle, the grid fills the available space without
// extra width/height bindings on the call site.
export component GridView inherits Rectangle {
    // --- Layout configuration ------------------------------------------------

    in property <int> columns: 3;
    in property <length> cell-width: 100px;
    in property <length> cell-height: 100px;
    in property <length> spacing: 0px;
    // Inner edge inset around the grid. Named `inset` rather than
    // `padding` because Rectangle reserves `padding` for layout-engine
    // use and refuses to be overridden.
    in property <length> inset: 0px;

    // Mirror of the caller's model length. `@children` exposes neither
    // a row count nor the iterated model, so we accept it as input and
    // use it to drive `row-count` / `content-height`.
    in property <int> item-count: 0;

    // --- Derived geometry ----------------------------------------------------

    // Ceiling division. Exposed so callers can hang scrollbar overlays,
    // "X of Y" counters, etc., off the same value the view uses
    // internally.
    out property <int> row-count:
        columns > 0 ? floor((max(item-count, 0) + columns - 1) / columns) : 0;

    // Total content extent (rows × cell-height + inter-row spacing +
    // vertical padding). Drives the Flickable's `viewport-height`.
    out property <length> content-height:
        row-count <= 0 ? 0px : row-count * cell-height + (row-count - 1) * spacing + 2 * inset;

    out property <length> content-width:
        columns <= 0 ? 0px : columns * cell-width + (columns - 1) * spacing + 2 * inset;
    // Fill by default — most call sites want the grid to take the whole
    // panel and let the Flickable handle overflow.
    horizontal-stretch: 1;
    vertical-stretch: 1;
    background: transparent;

    // --- Public placement helpers --------------------------------------------
    //
    // Caller binds these onto its repeated child's `x`/`y`. Pure, so
    // Slint can inline them at every for-loop instantiation without
    // tracking dependencies beyond the inputs.

    public pure function cell-x(i: int) -> length {
        inset + mod(i, columns) * (cell-width + spacing)
    }
    public pure function cell-y(i: int) -> length {
        inset + floor(i / columns) * (cell-height + spacing)
    }

    // --- Viewport ------------------------------------------------------------

    Flickable {
        width: 100%;
        height: 100%;

        // `max(...)` keeps the viewport at least as wide/tall as the
        // visible area when the grid is empty / under-filled. Slint's
        // Flickable clamps `viewport-x` / `viewport-y` to
        // `[-(viewport-* - *), 0]`, so viewport-* == * collapses to "no
        // scrolling", which is the behavior we want when content fits.
        // When the panel is narrower than `columns * cell-width`, the
        // extra width lets the user scroll horizontally rather than
        // silently clipping tiles.
        viewport-width: max(self.width, root.content-width);
        viewport-height: max(self.height, root.content-height);

        @children
    }
}
