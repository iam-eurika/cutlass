import { DragState } from "../models/drag_state.slint";

// Lightweight drag preview: a square that follows the pointer, morphing
// into a wider clip-shaped rect while hovering the timeline drop zone.
export component DragGhost inherits Rectangle {
    width: DragState.over-timeline ? 240px : 100px; //TODO: update this later to be the actual width of the media with time and zoom
    height: DragState.over-timeline ? 36px : 100px;
    // x: DragState.over-timeline ? DragState.x : DragState.x - self.width / 2;
    x: DragState.x;
    y: DragState.y - self.height / 2;
    background: DragState.over-timeline ? #4a5cff66 : #ffffff33;
    border-width: 2px;
    border-color: DragState.over-timeline ? #5b6eff : #ffffffaa;
    border-radius: DragState.over-timeline ? 4px : 0px;

    animate width, height, background, border-color, border-radius {
        duration: 80ms;
        easing: ease-out;
    }
}
